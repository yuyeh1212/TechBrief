# Database (Zeabur PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/techbrief

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-xxxxx
OPENROUTER_MODEL=google/gemini-2.5-pro-preview

# Resend
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# LINE
LINE_CHANNEL_ACCESS_TOKEN=xxxxx
LINE_CHANNEL_SECRET=xxxxx

# Unsplash (optional, 補圖用)
UNSPLASH_ACCESS_KEY=xxxxx

# Scheduler
NEWS_FETCH_HOUR=10
NEWS_FETCH_MINUTE=0
ARTICLES_PER_RUN=10

# CORS (前端網址)
CORS_ORIGINS=["https://techbrief.zeabur.app","http://localhost:5173"]

DEBUG=false

# Admin（自己設一個隨機字串，用於手動觸發任務）
ADMIN_TOKEN=your-random-secret-here
